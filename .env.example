# Copy this file to .env and fill in your provider details.
# Do NOT commit .env.

# Example: OpenAI-compatible provider
# AIGEST_BASE_URL=https://api.your-provider.example/v1
# AIGEST_MODEL=your-cheap-worker-model

# Example: DeepSeek (OpenAI-compatible)
# AIGEST_BASE_URL=https://api.deepseek.com
# AIGEST_MODEL=deepseek-v4-flash
#
# Example: Gemini API (OpenAI-compatible)
# You can use AIGEST_API_KEY or GEMINI_API_KEY.
# AIGEST_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# AIGEST_MODEL=gemini-2.5-flash

# Example: Ollama (local, OpenAI-compatible at /v1)
# AIGEST_PROVIDER=local
# AIGEST_BASE_URL=http://localhost:11434/v1
# AIGEST_MODEL=llama3.2
#
# Example: LM Studio (local, OpenAI-compatible at /v1)
# AIGEST_PROVIDER=local
# AIGEST_BASE_URL=http://localhost:1234/v1
# AIGEST_MODEL=local-model
#
# Example: Azure AI Foundry / Azure OpenAI Service (OpenAI v1, OpenAI-compatible)
# AIGEST_PROVIDER=azure
# AIGEST_API_KEY=<azure-resource-key>      # or set AZURE_OPENAI_API_KEY
#
# Pick the hostname that matches your deployment's catalog:
#   *.openai.azure.com         -> Azure OpenAI Service     (OpenAI's own models: gpt-4o, gpt-5, o-series)
#   *.services.ai.azure.com    -> Azure AI Foundry catalog (Kimi K2, DeepSeek, Llama, Mistral, etc.)
# Both expose the same /openai/v1/ path and accept the same API key. Wrong hostname
# returns HTTP 401 on the reachability probe even when the key is valid.
#
# AIGEST_BASE_URL=https://<resource>.openai.azure.com/openai/v1/
# AIGEST_BASE_URL=https://<resource>.services.ai.azure.com/openai/v1/
# AIGEST_MODEL=<deployment-name>

# Optional. Set to 'local' for Ollama / LM Studio / llama.cpp-server (OpenAI-compatible
# at /v1). In local mode: AIGEST_API_KEY is optional, AIGEST_THINKING_EFFORT is ignored,
# default timeout is 600s, and default base URL is http://localhost:11434/v1 (Ollama).
# Accepted values: local | cloud (default) | azure.
# AIGEST_PROVIDER=

AIGEST_API_KEY=
AIGEST_BASE_URL=https://api.deepseek.com
AIGEST_MODEL=deepseek-v4-flash

# Conservative safety limits.
AIGEST_MAX_FILE_BYTES=800000
AIGEST_MAX_TOTAL_BYTES=4000000
AIGEST_TIMEOUT_SECONDS=120

# Optional: cap on the model's output tokens (sum of reasoning + visible content for reasoning models).
# Leave unset to use the per-command default: 8192 for `ask`, 16384 for `write`.
# Reasoning-capable Azure / OpenAI deployments (gpt-5, o-series) need a much larger budget when
# AIGEST_THINKING_EFFORT is high or xhigh — try 32768 or higher.
# AIGEST_MAX_TOKENS=

# Keep this as 0 unless debugging the local CLI.
# Avoid logging full prompts/source code.
AIGEST_DEBUG=0

# Optional: upstream reasoning effort. Accepts: low | medium | high | xhigh. Leave unset to disable.
# xhigh uses maximum reasoning; supported on OpenAI GPT-5.1-Codex-Max and newer.
# - OpenAI o-series & gpt-5: forwarded as reasoning_effort.
# - Gemini 2.5 (OpenAI-compat endpoint): forwarded as reasoning_effort.
# - DeepSeek: reasoning is delivered via a separate model — set AIGEST_MODEL=deepseek-reasoner.
#   Sending this var to deepseek-chat may be ignored or rejected by the API.
# - Generic OpenAI-compat endpoints: forwarded as reasoning_effort; provider may ignore.
# - Local providers (AIGEST_PROVIDER=local): not forwarded; CheckCommand reports it as ignored.
# AIGEST_THINKING_EFFORT=
