{
  "service": {
    "name": "inventory-api",
    "port": 8080,
    "environment": "local"
  },
  "features": {
    "enableBackorder": true,
    "enableWarehouseSync": false
  },
  "dependencies": {
    "catalogApiBaseUrl": "https://catalog.internal.example",
    "warehouseApiBaseUrl": "https://warehouse.internal.example",
    "redisHost": "localhost",
    "redisPort": 6379
  },
  "auth": {
    "issuer": "https://auth.example.test",
    "audience": "inventory-api",
    "apiKey": "PLACEHOLDER_DO_NOT_USE"
  }
}

